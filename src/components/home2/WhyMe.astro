---
import Container from '../layout/Container.astro';

interface Props {
  locale: 'en' | 'es';
}

const { locale } = Astro.props;

const content = {
  en: {
    heading: 'Why Work With Me',
    differentiators: [
      {
        title: "You Never Wonder What's Happening",
        desc: "Most consultants vanish after the kickoff call. You get my number, my calendar, and direct access to the person building your system — no account manager filtering your questions, no project handoffs. You always know exactly where things stand.",
        icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
      },
      {
        title: "Your System Fits Your Business, Not a Template",
        desc: "Before I write a line of code, I map your actual workflow and define what 'working' looks like in your business. You get a clear plan and a testable prototype — not a generic chatbot with your logo slapped on it.",
        icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
      },
      {
        title: "Your Customers Find the Bugs — I Do",
        desc: "Everything is tested against real edge cases before it goes live. Input validation, error handling, bilingual responses under weird conditions — I find the failure modes before your customers do.",
        icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
      },
      {
        title: "You See What It's Doing for Your Revenue",
        desc: "Response time, leads captured, messages deflected, appointments booked — built-in tracking from launch day. You see the business numbers, not just a working product.",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
      }
    ]
  },
  es: {
    heading: 'Por Qué Trabajar Conmigo',
    differentiators: [
      {
        title: "Nunca Vas a Preguntarte Qué Está Pasando",
        desc: "La mayoría de los consultores desaparecen después de la primera llamada. Tienes acceso directo a mí — sin gerentes de cuentas, sin intermediarios. Siempre sabes exactamente en qué punto va tu proyecto.",
        icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
      },
      {
        title: "Tu Sistema Encaja en Tu Negocio, No al Revés",
        desc: "Antes de escribir una línea de código, mapeo cómo funciona tu operación y defino qué significa 'funcionando' para tu negocio. Recibes un plan claro y un prototipo que puedes probar — no un chatbot genérico con tu logo.",
        icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
      },
      {
        title: "Tus Clientes No Encuentran los Errores — Yo Sí",
        desc: "Todo se prueba en condiciones reales antes de salir en vivo. Validaciones, manejo de errores, respuestas bilingües en situaciones inesperadas — yo encuentro los puntos de falla antes que tus clientes.",
        icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
      },
      {
        title: "Ves Qué Está Haciendo por Tu Negocio",
        desc: "Tiempo de respuesta, leads capturados, mensajes atendidos, citas agendadas — analíticas integradas desde el primer día. Ves los números del negocio, no solo un producto que funciona.",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
      }
    ]
  }
};

const t = content[locale];
---

<section aria-labelledby="why-cushlabs-heading" class="py-20 md:py-32 bg-gray-50 dark:bg-gray-900/30">
  <Container size="lg">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 id="why-cushlabs-heading" class="font-display font-bold text-3xl md:text-4xl text-gray-900 dark:text-white leading-tight">
        {t.heading}
      </h2>
    </div>

    <div class="space-y-6 max-w-4xl mx-auto">
      {t.differentiators.map((diff) => (
        <div class="group p-6 md:p-8 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 flex flex-col md:flex-row gap-6 hover:border-cush-orange/50 hover:shadow-lg hover:shadow-cush-orange/5 transition-all duration-300">
          <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-cush-orange/10 flex items-center justify-center group-hover:bg-cush-orange group-hover:text-white dark:text-white text-gray-900 transition-colors duration-300">
            <svg class="w-7 h-7 text-cush-orange group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={diff.icon} />
            </svg>
          </div>
          <div>
            <h3 class="font-display font-semibold text-xl text-gray-900 dark:text-white mb-3 tracking-tight">
              {diff.title}
            </h3>
            <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed md:pr-4">
              {diff.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href={locale === 'es' ? '/es/reservar/' : '/consultation/'}
        class="inline-flex items-center gap-2 px-8 py-4 bg-cush-orange text-white font-display font-semibold rounded-lg hover:bg-cush-orange/90 transition-all duration-300 shadow-lg shadow-cush-orange/25 hover:shadow-xl hover:shadow-cush-orange/30 text-lg group"
      >
        {locale === 'es' ? 'Agendar Llamada Gratis' : 'Book Free Discovery Call'}
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </Container>
</section>
