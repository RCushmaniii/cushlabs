---
import Container from '../layout/Container.astro';

interface Props {
  locale: 'en' | 'es';
}

const { locale } = Astro.props;

const content = {
  en: {
    heading: "Recent Client & Production Work",
    projects: [
      {
        title: "AI Voice Agent Platform",
        tags: "Vapi · Claude Sonnet · Deepgram · Google Calendar",
        desc: "Production voice AI agents that qualify leads, book appointments, and handle support calls 24/7 with sub-500ms response times.",
        image: "/images/portfolio/thumbs/voice-cushlabs-thumb.webp",
        link: "/projects/cushlabs-ai-voice-agent"
      },
      {
        title: "Converso AI",
        tags: "Next.js 16 · PostgreSQL + pgvector · Stripe · OpenAI",
        desc: "Multi-tenant SaaS chatbot platform with RAG intelligence, visual playbook builder, and bilingual support for service businesses.",
        image: "/images/portfolio/thumbs/ai-chatbot-saas-thumb.webp",
        link: "/projects/ai-chatbot-saas"
      },
      {
        title: "NY AI Chatbot",
        tags: "Next.js 15 · TypeScript · OpenAI GPT-4o · pgvector",
        desc: "Revenue-first RAG chatbot that converts website visitors into booked strategy sessions for a real paying client.",
        image: "/images/portfolio/thumbs/ny-ai-chatbot-thumb.webp",
        link: "/projects/ny-ai-chatbot"
      }
    ],
    cta: "See All Projects →",
    ctaLink: "/portfolio"
  },
  es: {
    heading: "Trabajo Reciente en Producción",
    projects: [
      {
        title: "Plataforma de Agente de Voz IA",
        tags: "Vapi · Claude Sonnet · Deepgram · Google Calendar",
        desc: "Agentes de voz IA en producción que califican prospectos, agendan citas y atienden llamadas 24/7 con tiempos de respuesta menores a 500ms.",
        image: "/images/portfolio/thumbs/voice-cushlabs-thumb.webp",
        link: "/es/projects/cushlabs-ai-voice-agent"
      },
      {
        title: "Converso AI",
        tags: "Next.js 16 · PostgreSQL + pgvector · Stripe · OpenAI",
        desc: "Plataforma SaaS multi-inquilino de chatbot con inteligencia RAG, constructor visual de flujos y soporte bilingüe para negocios de servicio.",
        image: "/images/portfolio/thumbs/ai-chatbot-saas-thumb.webp",
        link: "/es/projects/ai-chatbot-saas"
      },
      {
        title: "Chatbot IA NY",
        tags: "Next.js 15 · TypeScript · OpenAI GPT-4o · pgvector",
        desc: "Chatbot RAG enfocado en ingresos que convierte visitantes del sitio web en sesiones de estrategia agendadas para un cliente real.",
        image: "/images/portfolio/thumbs/ny-ai-chatbot-thumb.webp",
        link: "/es/projects/ny-ai-chatbot"
      }
    ],
    cta: "Ver Todos Los Proyectos →",
    ctaLink: "/es/portfolio"
  }
};

const t = content[locale];
---

<section id="work" aria-labelledby="recent-work-heading" class="py-20 md:py-32 relative">
  <Container size="lg">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <h2 id="recent-work-heading" class="font-display font-bold text-3xl md:text-4xl text-gray-900 dark:text-white leading-tight">
        {t.heading}
      </h2>
      <a href={t.ctaLink} class="inline-flex items-center gap-2 text-cush-orange font-medium hover:underline text-lg whitespace-nowrap transition-colors duration-300 hover:text-cush-orange/80">
        {t.cta}
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {t.projects.map((project) => (
        <a href={project.link} class="group rounded-xl overflow-hidden border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 hover:border-cush-orange/40 hover:shadow-xl hover:shadow-cush-orange/10 hover:-translate-y-1 transition-all duration-500 ease-out flex flex-col h-full">
          <div class="aspect-[4/3] bg-gray-100 dark:bg-gray-800 relative overflow-hidden shimmer">
            <img
              src={project.image}
              alt={project.title}
              loading="lazy"
              width="760"
              height="570"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out img-fade"
              onload="this.classList.add('loaded');this.parentElement.classList.remove('shimmer')"
            />
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <div class="text-xs font-display font-semibold text-cush-orange uppercase tracking-wider mb-2">
              {project.tags}
            </div>
            <h3 class="font-display font-semibold text-xl text-gray-900 dark:text-white mb-3 group-hover:text-cush-orange transition-colors duration-500 ease-out">
              {project.title}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mt-auto">
              {project.desc}
            </p>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
