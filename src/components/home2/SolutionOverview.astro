---
import Container from '../layout/Container.astro';

interface Props {
  locale: 'en' | 'es';
}

const { locale } = Astro.props;

interface Pillar {
  title: string;
  desc: string;
  icon: string;
  href?: string;
  linkLabel?: string;
  badge?: string;
}

interface LocaleContent {
  heading: string;
  body: string;
  pillars: Pillar[];
  differentiator: string;
  cta: string;
  ctaLink: string;
}

const content: Record<'en' | 'es', LocaleContent> = {
  en: {
    heading: 'Three AI Systems. One Goal: Your Business Running Smarter.',
    body: "Unanswered Facebook messages, no idea where you stand on Google Maps, phones ringing while you're with a customer. These aren't small annoyances — they're revenue walking out the door. I fix all three with AI systems built around your specific business.",
    pillars: [
      {
        title: "AI Assistant on Facebook Messenger",
        desc: "Answers every customer message in seconds — prices, availability, appointments — in English and Spanish. 24/7. Trained on your products and your voice.",
        icon: "M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z",
        href: "/messenger-assistant/",
        linkLabel: "See the live demo",
        badge: "Live now"
      },
      {
        title: "Competitive Intelligence + Weekly Action Plan",
        desc: "I monitor your Google Maps rankings and competitors every week, then send you one clear action every Monday. No dashboards, no spreadsheets — just what to do.",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
      },
      {
        title: "AI Voice Agent",
        desc: "Answers your phone on the first ring, books appointments, captures leads — even at 2 AM on a Sunday. Natural voice, bilingual, trained on your services.",
        icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
      }
    ],
    differentiator: "Every system is trained on YOUR business — not a generic template.",
    cta: 'See My Services →',
    ctaLink: '/services/'
  },
  es: {
    heading: 'Tres Sistemas de IA. Un Objetivo: Tu Negocio Funcionando Mejor.',
    body: "Mensajes de Facebook sin contestar, no saber dónde estás en Google Maps, el teléfono sonando mientras atiendes a un cliente. Estos no son pequeños inconvenientes — son clientes que se van. Resuelvo los tres con sistemas de IA construidos para tu negocio específico.",
    pillars: [
      {
        title: "Asistente de IA en Facebook Messenger",
        desc: "Contesta cada mensaje de cliente en segundos — precios, disponibilidad, citas — en español e inglés. 24/7. Entrenado con tus productos y tu voz.",
        icon: "M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z",
        href: "/es/messenger-assistant/",
        linkLabel: "Ver la demo en vivo",
        badge: "En vivo"
      },
      {
        title: "Inteligencia Competitiva + Plan de Acción Semanal",
        desc: "Monitoreo tus posiciones en Google Maps y a tus competidores cada semana, y te envío una acción clara cada lunes. Sin dashboards, sin hojas de cálculo — solo lo que debes hacer.",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
      },
      {
        title: "Agente de Voz con IA",
        desc: "Contesta tu teléfono al primer timbrazo, agenda citas y captura leads — incluso a las 2 AM un domingo. Voz natural, bilingüe, entrenado con tus servicios.",
        icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
      }
    ],
    differentiator: "Cada sistema se entrena con TU negocio — no con una plantilla genérica.",
    cta: 'Ver Mis Servicios →',
    ctaLink: '/es/services/'
  }
};

const t = content[locale];
---

<section aria-labelledby="solutions-heading" class="py-20 md:py-32 relative">
  <Container size="lg">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Left text -->
      <div>
        <h2 id="solutions-heading" class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
          {t.heading}
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
          {t.body}
        </p>

        <div class="flex flex-wrap gap-4">
          <a href={locale === 'es' ? '/es/reservar/' : '/consultation/'} class="inline-flex items-center gap-2 px-6 py-3 bg-cush-orange text-white font-display font-semibold rounded-lg hover:bg-cush-orange/90 transition-all duration-300 shadow-lg shadow-cush-orange/25 hover:shadow-xl hover:shadow-cush-orange/30 group">
            {locale === 'es' ? 'Agendar Llamada Gratis' : 'Book a Free Call'}
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href={t.ctaLink} class="inline-flex items-center gap-2 px-6 py-3 border-2 border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-display font-semibold rounded-lg hover:border-cush-orange hover:text-cush-orange transition-all duration-300">
            {t.cta}
          </a>
        </div>
      </div>

      <!-- Right list -->
      <div class="space-y-8">
        <p class="text-sm font-display font-semibold uppercase tracking-wider text-cush-orange mb-6">
          {locale === 'en' ? 'That looks like:' : 'Esto se ve así:'}
        </p>
        
        {t.pillars.map((pillar, _i) => (
          <div class="flex gap-5 group">
            <div class="shrink-0 w-12 h-12 rounded-full bg-cush-orange/10 flex items-center justify-center group-hover:bg-cush-orange group-hover:text-white dark:text-white text-gray-900 transition-colors duration-300">
              <svg class="w-6 h-6 text-cush-orange group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={pillar.icon} />
              </svg>
            </div>
            <div>
              <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
                <strong class="font-semibold text-gray-900 dark:text-white block sm:inline">
                  {pillar.title}
                  {pillar.badge && (
                    <span class="inline-flex items-center gap-1.5 ml-2 px-2 py-0.5 rounded-full bg-green-500/10 border border-green-500/20 text-green-600 dark:text-green-400 text-xs font-semibold align-middle whitespace-nowrap">
                      <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                      {pillar.badge}
                    </span>
                  )}
                </strong> {pillar.desc}
              </p>
              {pillar.href && (
                <a
                  href={pillar.href}
                  class="inline-flex items-center gap-1.5 mt-2 font-display text-sm font-semibold text-cush-orange hover:text-cush-orange/80 transition-colors group/link"
                >
                  {pillar.linkLabel}
                  <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}

        <div class="mt-8 p-5 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-800 text-sm text-gray-600 dark:text-gray-400">
          <svg class="w-5 h-5 text-green-500 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {locale === 'en' 
            ? 'Every system includes validated answers, analytics, and clean documentation.'
            : 'Cada sistema incluye respuestas validadas, analíticas y documentación clara.'}
        </div>
      </div>
    </div>
  </Container>
</section>
