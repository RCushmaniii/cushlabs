---
import Container from '../layout/Container.astro';

interface Props {
  locale: 'en' | 'es';
}

const { locale } = Astro.props;

const content = {
  en: {
    heading: 'Common Questions',
    faqs: [
      {
        q: "How much does this cost? Is it SMB-affordable?",
        a: "Plans start at $1,990 MXN/mo (Basic) and go up to $5,490 (Ultra) — see the full breakdown on the Pricing page. Everything's a simple monthly subscription: no setup fees, no contracts, and a free 2-week trial. The discovery call is free — I'll recommend the right plan before you commit to anything."
      },
      {
        q: "How long does implementation take?",
        a: "Most productized setups — Messenger assistant, website chatbot, reviews — go live within days of your completed intake form. More complex custom builds (document processing, custom integrations) can take a few weeks. Either way, I show you progress the whole way."
      },
      {
        q: "What if the AI gives wrong answers?",
        a: "This is exactly why I build with validation and guardrails. Every system grounds answers in your approved content — not the open internet. When the AI isn't confident, it hands off to your team instead of guessing. I also include monitoring so you can see what's being asked and catch gaps early."
      },
      {
        q: "How do you handle data security?",
        a: "Secure by default. Your business data stays in controlled environments with proper access controls, encryption, and logging. I don't use your data to train models. I document all data handling practices and hand them over so your team knows exactly what's happening."
      },
      {
        q: "Do you work with companies in Mexico?",
        a: "Yes — I'm based in Guadalajara and work with businesses across Mexico, the U.S., and LATAM. All systems support bilingual (EN/ES) output. Project communication is English-first for speed, with Spanish available for any stakeholder conversations."
      },
      {
        q: "What if I'm not sure AI is the right solution?",
        a: "That's what the discovery call is for. I'll assess your situation honestly. If AI isn't the right move — or if the timing isn't right — I'll tell you directly and point you toward what would actually help. No hard sell."
      }
    ],
    cta: "View All FAQs →",
    ctaLink: "/faq/"
  },
  es: {
    heading: 'Preguntas Frecuentes',
    faqs: [
      {
        q: "¿Cuánto cuesta esto? ¿Es asequible para PYMES?",
        a: "Los planes comienzan en $1,990 MXN/mes (Básico) y llegan hasta $5,490 (Ultra) — puedes ver el desglose completo en la página de Precios. Todo es una suscripción mensual simple: sin cuotas de instalación, sin contratos y con prueba gratis de 2 semanas. La llamada de descubrimiento es gratuita — te recomiendo el plan correcto antes de que te comprometas a nada."
      },
      {
        q: "¿Cuánto tiempo toma la implementación?",
        a: "La mayoría de las configuraciones productizadas — asistente de Messenger, chatbot para tu sitio, reseñas — entran en vivo pocos días después de completar tu formulario. Los desarrollos a la medida más complejos (procesamiento de documentos, integraciones personalizadas) pueden tomar unas semanas. En cualquier caso, te muestro el progreso todo el tiempo."
      },
      {
        q: "¿Qué pasa si la IA da respuestas incorrectas?",
        a: "Por eso construyo con validación y barreras de seguridad. Cada sistema basa sus respuestas en tu contenido aprobado — no en la internet abierta. Cuando la IA no está segura, transfiere a tu equipo en lugar de adivinar. También incluyo monitoreo para que veas qué se está preguntando y detectes vacíos temprano."
      },
      {
        q: "¿Cómo manejas la seguridad de los datos?",
        a: "Seguro por diseño. Los datos de negocio se mantienen en entornos controlados con los adecuados controles de acceso. No uso tus datos para entrenar modelos. Documento todo y entrego las políticas de manejo de datos a tu equipo."
      },
      {
        q: "¿Trabajas con empresas en México?",
        a: "Sí — estoy basado en Guadalajara y trabajo con empresas en México, EE.UU. y LATAM. Todos los sistemas soportan salidas bilingües. La comunicación del proyecto es en inglés para agilidad, con español disponible para conversaciones clave."
      },
      {
        q: "¿Qué pasa si no estoy seguro de que la IA sea la solución?",
        a: "Para eso es la llamada de descubrimiento. Evaluaré tu situación honestamente. Si la IA no es lo adecuado — o el momento no es el correcto — te lo diré directamente y te orientaré hacia lo que realmente te ayudaría. Sin ventas forzadas."
      }
    ],
    cta: "Ver Todas las FAQs →",
    ctaLink: "/es/faq/"
  }
};

const t = content[locale];

// Build FAQPage structured data for rich snippets
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

<section aria-labelledby="faq-heading" class="py-20 md:py-32 bg-gray-50 dark:bg-gray-900/30">
  <Container size="md">
    <div class="text-center mb-16">
      <h2 id="faq-heading" class="font-display font-bold text-3xl md:text-4xl text-gray-900 dark:text-white leading-tight">
        {t.heading}
      </h2>
    </div>

    <div class="space-y-4 max-w-3xl mx-auto">
      {t.faqs.map((faq) => (
        <details class="group border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 rounded-xl overflow-hidden [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
            <h3 class="font-display font-semibold text-lg text-gray-900 dark:text-white group-open:text-cush-orange transition-colors">
              {faq.q}
            </h3>
            <span aria-hidden="true" class="shrink-0 ml-1.5 w-6 h-6 rounded-full border border-gray-300 dark:border-gray-700 flex items-center justify-center text-gray-500 group-open:rotate-180 transition-transform duration-300">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-gray-600 dark:text-gray-400 leading-relaxed border-t border-gray-100 dark:border-gray-800">
            {faq.a}
          </div>
        </details>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center gap-6">
      <a
        href={locale === 'es' ? '/es/reservar/' : '/consultation/'}
        class="inline-flex items-center gap-2 px-8 py-4 bg-cush-orange text-white font-display font-semibold rounded-lg hover:bg-cush-orange/90 transition-all duration-300 shadow-lg shadow-cush-orange/25 hover:shadow-xl hover:shadow-cush-orange/30 text-lg group"
      >
        {locale === 'es' ? 'Aún Tienes Dudas? Hablemos' : 'Still Have Questions? Let\'s Talk'}
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href={t.ctaLink} class="inline-flex items-center gap-2 text-cush-orange font-medium hover:underline text-lg transition-colors duration-300 hover:text-cush-orange/80">
        {t.cta}
      </a>
    </div>
  </Container>
</section>
