---
import Container from '../layout/Container.astro';

interface Props {
  locale: 'en' | 'es';
}

const { locale } = Astro.props;

const content = {
  en: {
    heading: 'See How It Works',
    body: "2 minutes. No jargon. I'll walk you through how I turn your scattered business knowledge into AI systems that actually work — and what the first 30 days look like.",
    cta: 'Prefer to talk? → Book a Call',
    ctaLink: '/consultation',
    label: 'See how it works',
    note: '2-minute video — no commitment',
  },
  es: {
    heading: 'Ver Cómo Funciona',
    body: "2 minutos. Sin jerga técnica. Te mostraré cómo convierto tu conocimiento disperso en sistemas de IA que realmente funcionan — y cómo se ven los primeros 30 días.",
    cta: '¿Prefieres hablar? → Agenda una Llamada',
    ctaLink: '/es/reservar',
    label: 'Ver cómo funciona',
    note: 'Video de 2 minutos — sin compromiso',
  }
};

const t = content[locale];
---

<section id="video" class="py-16 md:py-24 relative overflow-hidden">
  <Container size="lg">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Video Player -->
      <div class="relative rounded-xl overflow-hidden border border-gray-200 dark:border-gray-800 bg-gray-900 shadow-lg hover:shadow-xl hover:shadow-cush-orange/10 transition-all duration-300">
        <div id="video-container" class="relative aspect-video cursor-pointer group">
          <!-- Poster/Thumbnail -->
          <div id="video-poster" class="absolute inset-0">
            <img
              src="/images/portfolio/cushlabs-brief-poster.webp"
              alt="CushLabs AI portfolio brief video thumbnail"
              loading="lazy"
              width="1280"
              height="720"
              class="w-full h-full object-cover"
            />
            <!-- Play Button Overlay -->
            <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors">
              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-cush-orange/90 flex items-center justify-center group-hover:bg-cush-orange group-hover:scale-110 transition-all duration-300 shadow-lg shadow-black/30">
                  <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
                <p class="text-white font-display font-medium mb-1 drop-shadow-md">{t.label}</p>
                <p class="text-white/70 text-sm drop-shadow-md">{t.note}</p>
              </div>
            </div>
          </div>

          <!-- Video Element (lazy loaded, hidden until played) -->
          <video
            id="brief-video"
            class="w-full h-full object-cover hidden"
            controls
            preload="none"
            playsinline
          >
            <source src="/images/portfolio/cushlabs-brief.mp4" type="video/mp4" />
            <track kind="captions" />
          </video>
        </div>
      </div>

      <!-- Right: Supporting Text -->
      <div class="max-w-xl">
        <h2 class="font-display font-bold text-fluid-2xl md:text-fluid-3xl text-gray-900 dark:text-white mb-6">
          {t.heading}
        </h2>
        <p class="text-fluid-lg text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
          {t.body}
        </p>
        <a href={t.ctaLink} class="inline-flex items-center gap-2 text-cush-orange font-medium hover:underline text-lg">
          {t.cta}
        </a>
      </div>
    </div>
  </Container>
</section>

<script>
  const container = document.getElementById('video-container');
  const poster = document.getElementById('video-poster');
  const video = document.getElementById('brief-video') as HTMLVideoElement | null;

  if (container && poster && video) {
    // Preload video after page finishes loading (low priority)
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => {
        video.preload = 'auto';
      }, { timeout: 3000 });
    } else {
      // Fallback for Safari
      setTimeout(() => {
        video.preload = 'auto';
      }, 2000);
    }

    poster.addEventListener('click', () => {
      poster.classList.add('hidden');
      video.classList.remove('hidden');
      video.play();
    });

    video.addEventListener('ended', () => {
      video.pause();
      video.currentTime = 0;
      video.classList.add('hidden');
      poster.classList.remove('hidden');
    });
  }
</script>
