---
// Bilingual pricing section — 3-tier chart (Basic / Premium / Ultra).
// Shows the LIVE-NOW offering (WhatsApp + Instagram intentionally not listed
// until Meta approves; they layer into these tiers at no price change).
import type { Locale } from "../../i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const copy = {
  en: {
    eyebrow: "Pricing",
    heading: "Simple, transparent pricing",
    sub: "One monthly price. Everything set up and managed for you. No setup fees, no contracts.",
    perMonth: "MXN/mo",
    popular: "Most popular",
    bookHref: "/consultation/",
    tiers: [
      {
        name: "Basic",
        price: "$1,990",
        tagline: "For getting started",
        featured: false,
        features: [
          "AI assistant on Facebook Messenger (24/7)",
          "Google review management — with your approval",
          "Owner lead alerts",
          "Fully managed: setup, training, ongoing support",
        ],
        cta: "Get started",
      },
      {
        name: "Premium",
        price: "$3,490",
        tagline: "For growing businesses",
        featured: true,
        features: [
          "Everything in Basic",
          "Website chatbot",
          "Weekly local SEO & competitor report",
        ],
        cta: "Get started",
      },
      {
        name: "Ultra",
        price: "$5,490",
        tagline: "For clinics & high-volume businesses",
        featured: false,
        features: [
          "Everything in Premium",
          "AI Voice Agent — 300 answered min/mo ($8.50 MXN/min overage)",
          "Priority support",
          "Industry tuning (e.g. healthcare)",
        ],
        cta: "Get started",
      },
    ],
    notes:
      "No setup fee · No contracts · 2-week free trial · Pay via SPEI or OXXO · CFDI invoice included",
    footerQ: "Need something custom?",
    footerLink: "Let's talk",
    footerHref: "/contact/",
  },
  es: {
    eyebrow: "Precios",
    heading: "Precios simples y transparentes",
    sub: "Un solo precio al mes. Todo configurado y gestionado por nosotros. Sin cuotas de instalación, sin contratos.",
    perMonth: "MXN/mes",
    popular: "Más popular",
    bookHref: "/es/reservar/",
    tiers: [
      {
        name: "Básico",
        price: "$1,990",
        tagline: "Para empezar",
        featured: false,
        features: [
          "Asistente con IA en Facebook Messenger (24/7)",
          "Gestión de reseñas de Google — con tu aprobación",
          "Avisos de clientes listos para comprar",
          "Todo gestionado: configuración, entrenamiento y soporte",
        ],
        cta: "Empieza",
      },
      {
        name: "Premium",
        price: "$3,490",
        tagline: "Para negocios en crecimiento",
        featured: true,
        features: [
          "Todo lo de Básico",
          "Chatbot para tu sitio web",
          "Reporte semanal de SEO local y competencia",
        ],
        cta: "Empieza",
      },
      {
        name: "Ultra",
        price: "$5,490",
        tagline: "Para clínicas y negocios de alto volumen",
        featured: false,
        features: [
          "Todo lo de Premium",
          "Agente de Voz con IA — 300 minutos contestados/mes (excedente $8.50 MXN/min)",
          "Soporte prioritario",
          "Personalización por industria (p. ej. salud)",
        ],
        cta: "Empieza",
      },
    ],
    notes:
      "Sin cuota de instalación · Sin contratos · Prueba gratis de 2 semanas · Pago con SPEI u OXXO · Factura (CFDI) incluida",
    footerQ: "¿Necesitas algo a la medida?",
    footerLink: "Hablemos",
    footerHref: "/es/contact/",
  },
} as const;

const t = copy[locale];
---

<section class="relative overflow-hidden py-20 md:py-28">
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-cush-orange/10 rounded-full blur-[120px]"
    >
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p
        class="font-display text-sm font-semibold uppercase tracking-wider text-cush-orange mb-4"
      >
        {t.eyebrow}
      </p>
      <h1
        class="font-display text-fluid-4xl font-bold text-gray-900 dark:text-white mb-5 leading-tight tracking-tight"
      >
        {t.heading}
      </h1>
      <p class="text-fluid-lg text-gray-600 dark:text-gray-300 leading-relaxed">
        {t.sub}
      </p>
    </div>

    <!-- Tier cards -->
    <div class="grid gap-6 md:grid-cols-3 items-start">
      {
        t.tiers.map((tier) => (
          <div
            class={`relative rounded-2xl p-8 flex flex-col h-full ${
              tier.featured
                ? "border-2 border-cush-orange bg-white dark:bg-gray-800/60 shadow-xl md:-mt-4 md:mb-4"
                : "border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-800/30"
            }`}
          >
            {tier.featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-cush-orange text-white text-xs font-display font-semibold uppercase tracking-wide">
                {t.popular}
              </span>
            )}

            <h2 class="font-display text-xl font-bold text-gray-900 dark:text-white">
              {tier.name}
            </h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
              {tier.tagline}
            </p>

            <div class="mb-6 flex items-baseline gap-2">
              <span class="font-display text-4xl font-bold text-gray-900 dark:text-white">
                {tier.price}
              </span>
              <span class="text-gray-500 dark:text-gray-400">{t.perMonth}</span>
            </div>

            <ul class="space-y-3 mb-8 grow">
              {tier.features.map((f) => (
                <li class="flex gap-3">
                  <svg
                    class="w-5 h-5 text-cush-orange shrink-0 mt-0.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
                    {f}
                  </span>
                </li>
              ))}
            </ul>

            <a
              href={t.bookHref}
              class={`block w-full text-center px-6 py-3 rounded-lg font-display font-semibold transition-colors duration-300 ${
                tier.featured
                  ? "bg-cush-orange text-white hover:bg-cush-orange/90"
                  : "border border-gray-300 dark:border-gray-700 text-gray-900 dark:text-white hover:border-cush-orange hover:text-cush-orange"
              }`}
            >
              {tier.cta}
            </a>
          </div>
        ))
      }
    </div>

    <!-- Notes -->
    <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-10">
      {t.notes}
    </p>
    <p class="text-center text-sm text-gray-600 dark:text-gray-300 mt-4">
      {t.footerQ}{" "}
      <a
        href={t.footerHref}
        class="text-cush-orange font-semibold underline underline-offset-4 hover:opacity-80"
        >{t.footerLink}</a
      >
    </p>
  </div>
</section>
