---
import BaseLayout from "../layouts/BaseLayout.astro";

const content = {
  title: "Terms of Service | CushLabs.ai",
  description: "Terms and conditions for CushLabs.ai AI consulting and software development services. Clear expectations for projects, deliverables, and client relationships.",
  heading: "Terms of Service",
  lastUpdated: "Last updated: July 10, 2026",
  sections: [
    {
      title: "Acceptance of Terms",
      content: "By accessing or using CushLabs.ai services, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our services."
    },
    {
      title: "Services",
      content: "CushLabs.ai provides AI consulting, automation, and software development services. The specific scope, deliverables, and terms of any engagement will be outlined in a separate service agreement."
    },
    {
      title: "How the AI Assistant Works",
      content: "The assistant answers using the information you provide, and hands the conversation off to a member of your team when a request goes beyond what it can handle. It is a customer-service and sales tool; it does not replace professional advice and does not guarantee any specific sales result."
    },
    {
      title: "Your Responsibilities",
      content: "To deliver the service, we need you to be an administrator of the Facebook Page and Google Business Profiles we connect, or to grant the equivalent access, to provide accurate and current business information such as hours, prices, and addresses, and to review and approve the assistant's voice and content before it goes live. You are responsible for having the consent required to offer automated messaging to your own customers."
    },
    {
      title: "Intellectual Property",
      content: "Unless otherwise specified in a service agreement, you retain ownership of your data and content. CushLabs.ai retains ownership of its proprietary tools, methodologies, and pre-existing intellectual property."
    },
    {
      title: "Ownership of Deliverables",
      content: "Any website, content, and Google Business Profile setup we build for you as a one-time onboarding project become yours once paid for, and remain yours if you later cancel. The AI assistant software, our platform, and their internal configurations remain the property of CushLabs.ai and are licensed to you for the duration of your subscription."
    },
    {
      title: "Confidentiality",
      content: "We treat all client information as confidential. We will not disclose your business information to third parties without your consent, except as required by law."
    },
    {
      title: "Data & Privacy",
      content: "We treat your data and your customers' data as confidential and process it only to provide the service. For clients in Mexico, personal-data handling follows the Federal Law on the Protection of Personal Data Held by Private Parties (LFPDPPP), as described in our Privacy Policy. You are responsible for obtaining any consent your customers must give for automated service."
    },
    {
      title: "Payment Terms",
      content: "Payment terms will be specified in individual service agreements. Unless otherwise agreed, invoices are due within 30 days of receipt."
    },
    {
      title: "Subscriptions, Billing & Cancellation",
      content: "Subscription plans are billed monthly, in advance, and are priced per business, including up to 2 locations; additional locations are billed at the current published rate and begin only when that location is activated. Plan upgrades and added locations take effect from the next billing cycle, as do downgrades and removals. Every new plan includes a 1-week free trial; larger multi-location rollouts run the trial on one or two locations first, then expand once you continue. Payment is by bank transfer, and a CFDI invoice is included with every payment. Prepay options are available — quarterly prepayment earns 5% off the monthly rate and annual prepayment 10%, applied to the recurring subscription only. There is no fixed-term contract: you may cancel at any time, effective at the end of the current paid month, with no partial refund for that month. For prepaid quarters or years, unused full months may be refunded at the discounted rate. Full billing, invoicing, and non-payment procedures are set out in your individual service agreement."
    },
    {
      title: "Limitation of Liability",
      content: "CushLabs.ai shall not be liable for any indirect, incidental, special, or consequential damages arising from the use of our services, nor for interruptions caused by third-party platforms we rely on, including Meta/Facebook, Google, and hosting providers. Our total liability for any claim shall not exceed the fees you paid in the three months preceding the event giving rise to the claim."
    },
    {
      title: "Termination",
      content: "Either party may terminate a service engagement with written notice as specified in the service agreement. Upon termination, you remain responsible for any fees incurred prior to termination."
    },
    {
      title: "Governing Law",
      content: "These Terms are governed by and construed in accordance with the laws of the United Mexican States. The parties submit any dispute to the competent courts of Guadalajara, Jalisco, without prejudice to the rights that Mexican consumer-protection law (PROFECO) grants to the client."
    },
    {
      title: "Changes to Terms",
      content: "We reserve the right to modify these terms at any time. Continued use of our services after changes constitutes acceptance of the modified terms."
    },
    {
      title: "Contact",
      content: "For questions about these Terms of Service, please contact us at info@cushlabs.ai."
    }
  ]
};
---

<BaseLayout title={content.title} description={content.description}>
  <main class="min-h-screen bg-white dark:bg-gray-950">
    <!-- Hero -->
    <section class="relative pt-24 pb-12">
      <div class="absolute inset-0 -z-10">
        <div class="absolute top-20 left-1/4 w-96 h-96 bg-cush-orange/10 rounded-full blur-3xl"></div>
      </div>

      <div class="mx-auto max-w-3xl px-4 text-center">
        <h1 class="font-display text-4xl font-bold text-gray-900 dark:text-white md:text-5xl">
          {content.heading}
        </h1>
        <p class="mt-4 text-gray-500 dark:text-gray-400">
          {content.lastUpdated}
        </p>
      </div>
    </section>

    <!-- Content -->
    <section class="pb-24">
      <div class="mx-auto max-w-3xl px-4">
        <div class="prose prose-gray dark:prose-invert max-w-none">
          {content.sections.map((section) => (
            <div class="mb-8">
              <h2 class="font-display text-xl font-semibold text-gray-900 dark:text-white mb-3">
                {section.title}
              </h2>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                {section.content}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
