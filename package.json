{
  "name": "cushlabs-site",
  "version": "1.0.0",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate-projects && node scripts/validate-blog-translations.mjs && node scripts/generate-og-images.mjs && astro build && node scripts/seo/meta-description-gate.mjs",
    "start": "astro preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck",
    "astro:check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "validate:portfolio-md": "tsx scripts/validate-portfolio-md.ts",
    "sync:portfolio": "tsx scripts/sync-portfolio.ts",
    "generate-projects": "tsx scripts/validate-portfolio-md.ts && tsx scripts/generate-projects.ts",
    "og:blog": "node scripts/generate-og-images.mjs",
    "sync:all": "tsx scripts/sync-all.ts",
    "audit:predeploy": "tsx scripts/audit-predeploy.ts",
    "audit:portfolio": "tsx scripts/audit-portfolio.ts",
    "generate:skills": "tsx scripts/generate-skills.ts",
    "seo:indexnow": "node scripts/seo/indexnow-submit.mjs",
    "seo:gsc": "node scripts/seo/gsc-submit-urls.mjs --sitemap",
    "seo:gsc:url": "node scripts/seo/gsc-submit-urls.mjs --url",
    "seo:submit": "npm run seo:indexnow && npm run seo:gsc"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.2",
    "@sentry/astro": "^10.50.0",
    "@sentry/node": "^10.47.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.4.8",
    "googleapis": "^171.4.0",
    "tailwindcss": "^4.2.2"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "fast-xml-parser": ">=5.7.0",
    "vite": "^7.3.5",
    "qs": "^6.15.2",
    "@opentelemetry/core": "^2.8.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "gray-matter": "^4.0.3",
    "mime-types": "^3.0.2",
    "prettier": "^3.8.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
